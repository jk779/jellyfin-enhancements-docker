{
  order replace after reverse_proxy
  order replace before encode
}

:8096 {
  @injected path /inject/*

  handle @injected {
    root * /srv
    header {
      Content-Type application/javascript
      Cache-Control "public, max-age=3600"
    }
    file_server
  }

  reverse_proxy jellyfin:8096 {
    header_up Accept-Encoding identity
  }

  # Match Jellyfin web entrypoints
  @jellyweb path /web/ /web/index.html
  replace @jellyweb {
    re "(?i)</body>" `
<script defer src="/inject/frontend-search-filters.js"></script>
<script defer src="/inject/log-viewer-inject.js"></script>
<script defer src="/inject/native-right-click-title.js"></script>
<script defer src="/inject/previews-badges.js"></script>
<script defer src="/inject/search-flex-wrap.js"></script>
<script defer src="/inject/search-input-maxlength.js"></script>
</body>`
  }
}