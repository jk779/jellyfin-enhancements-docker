FROM caddy:latest

RUN set -eux; \
  arch="$(uname -m)"; \
  case "$arch" in \
    x86_64)  goarch=amd64 ;; \
    aarch64) goarch=arm64 ;; \
    *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
  esac; \
  curl -fsSL -o /usr/bin/caddy \
    "https://caddyserver.com/api/download?os=linux&arch=${goarch}&p=github.com/caddyserver/replace-response"; \
  chmod +x /usr/bin/caddy; \
  caddy version
